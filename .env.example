# ============================================================
# VARIABLES DE ENTORNO — MSTR Intelligence Bot v2.0
# Copia este archivo como .env y rellena tus credenciales
# NUNCA subas el .env a Git
# ============================================================

# ── MicroStrategy ─────────────────────────────────────────────
MSTR_BASE_URL=https://cencosud.cloud.microstrategy.com/MicroStrategyLibrary/api
MSTR_USERNAME=tu_usuario_aqui
MSTR_PASSWORD=tu_password_aqui
MSTR_PROJECT_ID=tu_project_id_aqui

# ── Supabase ──────────────────────────────────────────────────
# Obtén estos valores en: supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App ───────────────────────────────────────────────────────
SECRET_KEY=cambia_esto_por_un_string_aleatorio_largo
PORT=5000
FLASK_ENV=production

# ── Caché MicroStrategy (minutos) ─────────────────────────────
CACHE_TTL_MIN=30
